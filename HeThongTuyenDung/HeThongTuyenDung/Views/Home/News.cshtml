@{
    ViewData["Title"] = "Tin tức & Cẩm nang";
}

<!-- Spacer for fixed navbar -->
<div style="height: 100px;"></div>

<div class="container pb-5">
    <div class="row mb-5 text-center">
        <div class="col-lg-8 mx-auto">
            <span class="badge bg-primary bg-opacity-10 text-primary mb-2 px-3 py-2 rounded-pill fw-bold">BLOG & NEWS</span>
            <h1 class="display-4 fw-bold mb-3">Tin tức & Cẩm nang nghề nghiệp</h1>
            <p class="lead text-muted">
                Cập nhật những xu hướng tuyển dụng mới nhất, bí quyết phỏng vấn và lời khuyên phát triển sự nghiệp từ chuyên gia JOB NOW.
            </p>
        </div>
    </div>

    <!-- Featured Post -->
    <div class="card border-0 shadow-lg rounded-xl overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-lg-6 position-relative">
                <div style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); height: 100%; min-height: 300px;" class="d-flex align-items-center justify-content-center">
                    <i class="fas fa-newspaper text-white opacity-25" style="font-size: 8rem;"></i>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card-body p-4 p-lg-5 d-flex flex-column h-100 justify-content-center">
                    <div class="d-flex align-items-center mb-3">
                        <span class="badge bg-primary me-2">Mới nhất</span>
                        <small class="text-muted"><i class="fas fa-calendar-alt me-1"></i>23/12/2025</small>
                    </div>
                    <h2 class="card-title fw-bold mb-3">
                        <a href="#" class="text-dark text-decoration-none hover-primary">Top 10 kỹ năng IT được săn đón nhất năm 2026</a>
                    </h2>
                    <p class="card-text text-muted mb-4">
                        Thị trường công nghệ đang thay đổi chóng mặt. Cùng JOB NOW điểm qua những kỹ năng quan trọng mà mọi lập trình viên cần trang bị để bứt phá trong năm tới...
                    </p>
                    <a href="#" class="btn btn-outline-primary rounded-pill px-4 align-self-start">
                        Đọc tiếp <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Posts Grid -->
    <h3 class="fw-bold mb-4 border-start border-4 border-primary ps-3">Bài viết mới</h3>
    <div class="row g-4">
        <!-- Post 1 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-lg hover-lift">
                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                     <i class="fas fa-laptop-code fa-3x text-primary opacity-50"></i>
                </div>
                <div class="card-body p-4">
                    <div class="mb-2">
                        <span class="badge bg-info bg-opacity-10 text-info">Cẩm nang</span>
                    </div>
                    <h5 class="card-title fw-bold mb-3">
                        <a href="#" class="text-dark text-decoration-none">Cách viết CV "chuẩn chỉnh" chinh phục nhà tuyển dụng</a>
                    </h5>
                    <p class="card-text text-muted small mb-3">
                        CV là vũ khí đầu tiên giúp bạn gây ấn tượng. Hãy tránh những lỗi cơ bản và làm nổi bật thế mạnh của bản thân...
                    </p>
                </div>
                <div class="card-footer bg-white border-0 pt-0 pb-4 px-4">
                    <div class="d-flex justify-content-between align-items-center small text-muted">
                        <span><i class="fas fa-user me-1"></i>Admin</span>
                        <span><i class="far fa-clock me-1"></i>5 phút đọc</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 2 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-lg hover-lift">
                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                     <i class="fas fa-user-tie fa-3x text-success opacity-50"></i>
                </div>
                <div class="card-body p-4">
                    <div class="mb-2">
                        <span class="badge bg-success bg-opacity-10 text-success">Phỏng vấn</span>
                    </div>
                    <h5 class="card-title fw-bold mb-3">
                        <a href="#" class="text-dark text-decoration-none">Bí quyết trả lời câu hỏi "Điểm yếu của bạn là gì?"</a>
                    </h5>
                    <p class="card-text text-muted small mb-3">
                        Một câu hỏi kinh điển nhưng luôn làm khó ứng viên. Học cách biến điểm yếu thành điểm mạnh một cách khéo léo...
                    </p>
                </div>
                <div class="card-footer bg-white border-0 pt-0 pb-4 px-4">
                    <div class="d-flex justify-content-between align-items-center small text-muted">
                        <span><i class="fas fa-user me-1"></i>HR Manager</span>
                        <span><i class="far fa-clock me-1"></i>3 phút đọc</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 3 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-lg hover-lift">
                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                     <i class="fas fa-chart-line fa-3x text-warning opacity-50"></i>
                </div>
                <div class="card-body p-4">
                    <div class="mb-2">
                         <span class="badge bg-warning bg-opacity-10 text-warning">Xu hướng</span>
                    </div>
                    <h5 class="card-title fw-bold mb-3">
                        <a href="#" class="text-dark text-decoration-none">Review lương ngành IT năm 2025: Tăng hay giảm?</a>
                    </h5>
                    <p class="card-text text-muted small mb-3">
                        Báo cáo chi tiết về mức lương trung bình của các vị trí Frontend, Backend, DevOps và Mobile Developer tại Việt Nam...
                    </p>
                </div>
                <div class="card-footer bg-white border-0 pt-0 pb-4 px-4">
                    <div class="d-flex justify-content-between align-items-center small text-muted">
                        <span><i class="fas fa-user me-1"></i>Admin</span>
                        <span><i class="far fa-clock me-1"></i>10 phút đọc</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-5">
        <nav aria-label="Page navigation">
            <ul class="pagination">
                <li class="page-item disabled">
                    <a class="page-link border-0 rounded-circle mx-1" href="#" tabindex="-1"><i class="fas fa-chevron-left"></i></a>
                </li>
                <li class="page-item active"><a class="page-link border-0 rounded-circle mx-1" href="#">1</a></li>
                <li class="page-item"><a class="page-link border-0 rounded-circle mx-1" href="#">2</a></li>
                <li class="page-item"><a class="page-link border-0 rounded-circle mx-1" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link border-0 rounded-circle mx-1" href="#"><i class="fas fa-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg) !important;
    }
    .hover-primary:hover {
        color: var(--primary-color) !important;
    }
    .page-link {
        color: var(--text-muted);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .page-item.active .page-link {
        background-color: var(--primary-color);
        color: white;
    }
</style>

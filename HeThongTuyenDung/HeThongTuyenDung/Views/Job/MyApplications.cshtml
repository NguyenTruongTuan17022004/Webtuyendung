@model IEnumerable<HeThongTuyenDung.Models.DonUngTuyen>

@{
    ViewData["Title"] = "Hồ sơ ứng tuyển";
}

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    <i class="fas fa-file-alt text-primary me-2"></i>
                    Hồ sơ ứng tuyển
                </h2>
                <a href="@Url.Action("Index", "Job")" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i>
                    Quay lại trang chủ
                </a>
            </div>

            @if (Model.Any())
            {
                <div class="row g-4">
                    @foreach (var application in Model)
                    {
                        <div class="col-lg-6 col-md-12">
                            <div class="card application-card h-100 shadow-sm border-0">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center">
                                            <div class="company-logo bg-light rounded p-2 me-3">
                                                <i class="fas fa-building text-primary fa-2x"></i>
                                            </div>
                                            <div>
                                                <h5 class="card-title mb-1">
                                                    <a href="@Url.Action("Details", "Job", new { id = application.TinTuyenDung.MaTin })" class="text-decoration-none text-dark">
                                                        @application.TinTuyenDung.TieuDe
                                                    </a>
                                                </h5>
                                                <p class="text-muted mb-0">
                                                    <i class="fas fa-building me-2"></i>
                                                    @(application.TinTuyenDung?.CongTy?.TenCongTy ?? "Công ty không xác định")
                                                </p>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge @GetStatusBadgeClass(application.TrangThai) mb-2">
                                                @GetStatusText(application.TrangThai)
                                            </span>
                                            <small class="text-muted d-block">
                                                <i class="fas fa-calendar me-1"></i>
                                                Ứng tuyển: @application.NgayUngTuyen.ToString("dd/MM/yyyy")
                                            </small>
                                        </div>
                                    </div>

                                    <div class="row g-2 mb-3">
                                        <div class="col-md-6">
                                            <p class="text-muted mb-1">
                                                <i class="fas fa-map-marker-alt me-2"></i>
                                                @(application.TinTuyenDung.DiaDiem ?? "Không xác định")
                                            </p>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="text-muted mb-1">
                                                <i class="fas fa-briefcase me-2"></i>
                                                @(application.TinTuyenDung.DanhMucCongViec?.TenDanhMuc ?? "Khác")
                                            </p>
                                        </div>
                                    </div>

                                    @if (application.TinTuyenDung.HienThiLuong && application.TinTuyenDung.LuongTu.HasValue)
                                    {
                                        <p class="text-success fw-bold mb-3">
                                            <i class="fas fa-money-bill-wave me-2"></i>
                                            @application.TinTuyenDung.LuongTu.Value.ToString("N0") - @(application.TinTuyenDung.LuongDen?.ToString("N0") ?? "Thỏa thuận") @application.TinTuyenDung.DonViTien
                                        </p>
                                    }

                                    @if (!string.IsNullOrEmpty(application.GhiChu))
                                    {
                                        <div class="alert alert-info mb-3">
                                            <h6 class="mb-2">
                                                <i class="fas fa-comment me-2"></i>
                                                Ghi chú ứng tuyển
                                            </h6>
                                            <p class="mb-0">@application.GhiChu</p>
                                        </div>
                                    }

                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-primary me-2">@(application.TinTuyenDung.CapBacCongViec?.TenCapBac ?? "Không xác định")</span>
                                            @if (application.TinTuyenDung.NoiBat)
                                            {
                                                <span class="badge bg-warning text-dark">Nổi bật</span>
                                            }
                                        </div>
                                        <small class="text-muted">
                                            <i class="fas fa-eye me-1"></i>@application.TinTuyenDung.LuotXem lượt xem
                                        </small>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-0">
                                    <div class="d-flex gap-2">
                                        <a href="@Url.Action("Details", "Job", new { id = application.TinTuyenDung.MaTin })" class="btn btn-primary flex-fill">
                                            <i class="fas fa-eye me-2"></i>
                                            Xem chi tiết
                                        </a>
                                        @if (application.TrangThai == "Chờ xử lý")
                                        {
                                            <button class="btn btn-outline-warning" onclick="cancelApplication(@application.MaDon)">
                                                <i class="fas fa-times me-2"></i>
                                                Hủy đơn
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-5">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card border-0 bg-light">
                                <div class="card-body text-center">
                                    <h4 class="text-primary">@Model.Count(a => a.TrangThai == "Chờ xử lý")</h4>
                                    <p class="mb-0 text-muted">Đang chờ xử lý</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 bg-light">
                                <div class="card-body text-center">
                                    <h4 class="text-success">@Model.Count(a => a.TrangThai == "Chấp nhận")</h4>
                                    <p class="mb-0 text-muted">Được chấp nhận</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 bg-light">
                                <div class="card-body text-center">
                                    <h4 class="text-danger">@Model.Count(a => a.TrangThai == "Từ chối")</h4>
                                    <p class="mb-0 text-muted">Bị từ chối</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Chưa có đơn ứng tuyển nào</h4>
                    <p class="text-muted mb-4">Hãy tìm việc làm phù hợp và gửi đơn ứng tuyển!</p>
                    <a href="@Url.Action("Index", "Job")" class="btn btn-primary">
                        <i class="fas fa-search me-2"></i>
                        Tìm việc làm
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<script>
function cancelApplication(applicationId) {
    if (confirm('Bạn có chắc chắn muốn hủy đơn ứng tuyển này?')) {
        fetch('@Url.Action("CancelApplication", "Job")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `applicationId=${applicationId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showNotification(data.message, 'success');
                // Reload page after a short delay to update the list
                setTimeout(() => {
                    location.reload();
                }, 1500);
            } else {
                showNotification(data.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showNotification('Có lỗi xảy ra, vui lòng thử lại', 'error');
        });
    }
}

function showNotification(message, type) {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
    notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    document.body.appendChild(notification);
    
    // Auto remove after 3 seconds
    setTimeout(() => {
        if (notification.parentNode) {
            notification.remove();
        }
    }, 3000);
}
</script>

<style>
.application-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.application-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
}

.company-logo {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
}
</style>

@functions {
    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Chờ xử lý" => "bg-warning text-dark",
            "Chấp nhận" => "bg-success",
            "Từ chối" => "bg-danger",
            "Phỏng vấn" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetStatusText(string status)
    {
        return status switch
        {
            "Chờ xử lý" => "Chờ xử lý",
            "Chấp nhận" => "Được chấp nhận",
            "Từ chối" => "Bị từ chối",
            "Phỏng vấn" => "Mời phỏng vấn",
            _ => status
        };
    }
} 
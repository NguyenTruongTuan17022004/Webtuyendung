@model IEnumerable<HeThongTuyenDung.Models.TinDaLuu>

@{
    ViewData["Title"] = "Việc làm đã lưu";
}

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    <i class="fas fa-bookmark text-primary me-2"></i>
                    Việc làm đã lưu
                </h2>
                <a href="@Url.Action("Index", "Job")" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i>
                    Quay lại trang chủ
                </a>
            </div>

            @if (Model.Any())
            {
                <div class="row g-4">
                    @foreach (var savedJob in Model)
                    {
                        <div class="col-lg-6 col-md-12">
                            <div class="card job-card h-100 shadow-sm border-0">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center">
                                            <div class="company-logo bg-light rounded p-2 me-3">
                                                <i class="fas fa-building text-primary fa-2x"></i>
                                            </div>
                                            <div>
                                                <h5 class="card-title mb-1">
                                                    <a href="@Url.Action("Details", "Job", new { id = savedJob.TinTuyenDung.MaTin })" class="text-decoration-none text-dark">
                                                        @savedJob.TinTuyenDung.TieuDe
                                                    </a>
                                                </h5>
                                                <p class="text-muted mb-0">
                                                    <i class="fas fa-building me-2"></i>
                                                    @(savedJob.TinTuyenDung.CongTy?.TenCongTy ?? "Công ty không xác định")
                                                </p>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <small class="text-muted d-block">
                                                <i class="fas fa-calendar me-1"></i>
                                                Đã lưu: @savedJob.NgayLuu.ToString("dd/MM/yyyy")
                                            </small>
                                        </div>
                                    </div>

                                    <div class="row g-2 mb-3">
                                        <div class="col-md-6">
                                            <p class="text-muted mb-1">
                                                <i class="fas fa-map-marker-alt me-2"></i>
                                                @(savedJob.TinTuyenDung.DiaDiem ?? "Không xác định")
                                            </p>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="text-muted mb-1">
                                                <i class="fas fa-briefcase me-2"></i>
                                                @(savedJob.TinTuyenDung.DanhMucCongViec?.TenDanhMuc ?? "Khác")
                                            </p>
                                        </div>
                                    </div>

                                    @if (savedJob.TinTuyenDung.HienThiLuong && savedJob.TinTuyenDung.LuongTu.HasValue)
                                    {
                                        <p class="text-success fw-bold mb-3">
                                            <i class="fas fa-money-bill-wave me-2"></i>
                                            @savedJob.TinTuyenDung.LuongTu.Value.ToString("N0") - @(savedJob.TinTuyenDung.LuongDen?.ToString("N0") ?? "Thỏa thuận") @savedJob.TinTuyenDung.DonViTien
                                        </p>
                                    }

                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-primary me-2">@(savedJob.TinTuyenDung.CapBacCongViec?.TenCapBac ?? "Không xác định")</span>
                                            @if (savedJob.TinTuyenDung.NoiBat)
                                            {
                                                <span class="badge bg-warning text-dark">Nổi bật</span>
                                            }
                                        </div>
                                        <small class="text-muted">
                                            <i class="fas fa-eye me-1"></i>@savedJob.TinTuyenDung.LuotXem lượt xem
                                        </small>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-0">
                                    <div class="d-flex gap-2">
                                        <a href="@Url.Action("Details", "Job", new { id = savedJob.TinTuyenDung.MaTin })" class="btn btn-primary flex-fill">
                                            <i class="fas fa-eye me-2"></i>
                                            Xem chi tiết
                                        </a>
                                        <a href="@Url.Action("Apply", "Job", new { id = savedJob.TinTuyenDung.MaTin })" class="btn btn-outline-success">
                                            <i class="fas fa-paper-plane me-2"></i>
                                            Ứng tuyển
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-5">
                    <p class="text-muted">
                        <i class="fas fa-info-circle me-2"></i>
                        Bạn có thể xem chi tiết hoặc ứng tuyển trực tiếp từ danh sách việc làm đã lưu
                    </p>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-bookmark fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Chưa có việc làm nào được lưu</h4>
                    <p class="text-muted mb-4">Hãy duyệt qua các việc làm và lưu lại những việc làm bạn quan tâm!</p>
                    <a href="@Url.Action("Index", "Job")" class="btn btn-primary">
                        <i class="fas fa-search me-2"></i>
                        Tìm việc làm
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
.job-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.job-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
}

.company-logo {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
}
</style> 
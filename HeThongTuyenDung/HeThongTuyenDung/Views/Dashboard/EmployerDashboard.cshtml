@{
    ViewData["Title"] = "Dashboard - Doanh nghiệp";
}


<!-- Spacer for fixed navbar -->
<div style="height: 100px;"></div>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="fas fa-building me-2 text-success"></i>Dashboard Doanh nghiệp
            </h2>
        </div>
    </div>

    <!-- Thống kê tổng quan -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Tổng tin tuyển dụng
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalJobs</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-briefcase fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Tin đang hoạt động
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.ActiveJobs</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Tổng đơn ứng tuyển
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalApplications</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Chờ xử lý
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.PendingApplications</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông báo đơn ứng tuyển mới -->
    @{
        var unreadApplications = 0;
        if (ViewBag.RecentApplications != null)
        {
            var applications = ViewBag.RecentApplications as List<HeThongTuyenDung.Models.DonUngTuyen>;
            if (applications != null)
            {
                unreadApplications = applications.Count(a => !a.DaXem);
            }
        }
    }
    @if (unreadApplications > 0)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-bell fa-2x me-3"></i>
                        <div>
                            <h6 class="alert-heading mb-1">Có @unreadApplications đơn ứng tuyển mới!</h6>
                            <p class="mb-0">Bạn có @unreadApplications đơn ứng tuyển chưa xem. Hãy kiểm tra và xử lý sớm để không bỏ lỡ ứng viên tiềm năng.</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("ManageApplications", "Dashboard")" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye me-2"></i>
                            Xem ngay
                        </a>
                        <button type="button" class="btn btn-outline-primary btn-sm ms-2" onclick="markAllAsRead()">
                            <i class="fas fa-check-double me-2"></i>
                            Đánh dấu tất cả đã xem
                        </button>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <!-- Tin tuyển dụng gần đây -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-briefcase me-2"></i>Tin tuyển dụng gần đây
                    </h6>
                    <a asp-controller="Job" asp-action="PostJob" class="btn btn-sm btn-success">
                        <i class="fas fa-plus me-1"></i>Đăng tin mới
                    </a>
                </div>
                <div class="card-body">
                    @if (ViewBag.RecentJobs != null && ViewBag.RecentJobs.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var job in ViewBag.RecentJobs)
                            {
                                <div class="list-group-item border-0 px-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@job.TieuDe</h6>
                                            <small class="text-muted">@job.DiaDiem</small>
                                        </div>
                                        <span class="badge @(job.TrangThai ? "bg-success" : "bg-secondary")">
                                            @(job.TrangThai ? "Đang hoạt động" : "Tạm dừng")
                                        </span>
                                    </div>
                                    <small class="text-muted">
                                        <i class="fas fa-calendar me-1"></i>
                                        Đăng @job.NgayTao.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">
                            <i class="fas fa-briefcase fa-2x mb-2"></i><br>
                            Chưa có tin tuyển dụng nào
                        </p>
                    }
                </div>
            </div>
        </div>

        <!-- Đơn ứng tuyển gần đây -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-users me-2"></i>Đơn ứng tuyển gần đây
                    </h6>
                    <a asp-controller="Dashboard" asp-action="ManageApplications" class="btn btn-sm btn-primary">
                        Quản lý ứng viên
                    </a>
                </div>
                <div class="card-body">
                    @if (ViewBag.RecentApplications != null && ViewBag.RecentApplications.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var application in ViewBag.RecentApplications)
                            {
                                <div class="list-group-item border-0 px-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@application.NguoiDung.HoTen</h6>
                                            <small class="text-muted">Ứng tuyển: @application.TinTuyenDung.TieuDe</small>
                                        </div>
                                        <span class="badge @(application.TrangThai == "Chấp nhận" ? "bg-success" : 
                                                          application.TrangThai == "Từ chối" ? "bg-danger" : "bg-warning")">
                                            @application.TrangThai
                                        </span>
                                    </div>
                                    <small class="text-muted">
                                        <i class="fas fa-calendar me-1"></i>
                                        @application.NgayUngTuyen.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">
                            <i class="fas fa-users fa-2x mb-2"></i><br>
                            Chưa có đơn ứng tuyển nào
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Hành động nhanh -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-bolt me-2"></i>Hành động nhanh
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <a asp-controller="Job" asp-action="PostJob" class="btn btn-outline-success w-100">
                                <i class="fas fa-plus me-2"></i>Đăng tin tuyển dụng
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a asp-controller="Dashboard" asp-action="ManageApplications" class="btn btn-outline-primary w-100">
                                <i class="fas fa-users me-2"></i>Quản lý ứng viên
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-info w-100">
                                <i class="fas fa-building me-2"></i>Thông tin công ty
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="#" class="btn btn-outline-warning w-100">
                                <i class="fas fa-chart-line me-2"></i>Xem thống kê
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Biểu đồ thống kê (có thể thêm sau) -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-chart-bar me-2"></i>Thống kê ứng tuyển theo tháng
                    </h6>
                </div>
                <div class="card-body">
                    <div class="text-center py-4">
                        <i class="fas fa-chart-bar fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Biểu đồ thống kê sẽ được hiển thị ở đây</p>
                        <small class="text-muted">Tính năng đang phát triển</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.border-left-primary {
    border-left: 0.25rem solid #4e73df !important;
}

.border-left-success {
    border-left: 0.25rem solid #1cc88a !important;
}

.border-left-info {
    border-left: 0.25rem solid #36b9cc !important;
}

.border-left-warning {
    border-left: 0.25rem solid #f6c23e !important;
}

.text-xs {
    font-size: 0.7rem;
}

.text-gray-800 {
    color: #5a5c69 !important;
}

.text-gray-300 {
    color: #dddfeb !important;
}

.card {
    border: none;
    border-radius: 0.35rem;
}

.card-header {
    background-color: #f8f9fc;
    border-bottom: 1px solid #e3e6f0;
}
</style>

<script>
// Mark all as read function
function markAllAsRead() {
    if (confirm('Đánh dấu tất cả đơn ứng tuyển đã xem?')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '@Url.Action("MarkAllAsRead", "Dashboard")';
        
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '__RequestVerificationToken';
        tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        form.appendChild(tokenInput);
        
        document.body.appendChild(form);
        form.submit();
    }
}
</script> 
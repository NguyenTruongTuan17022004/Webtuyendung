@model HeThongTuyenDung.Models.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["HideLayout"] = true;
}

<div class="auth-wrapper">
    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100">
            <!-- Left Side: Hero/Branding -->
            <div class="col-lg-6 d-none d-lg-flex position-relative align-items-center justify-content-center bg-primary overflow-hidden">
                <div class="auth-bg-pattern position-absolute w-100 h-100" style="opacity: 0.1;"></div>
                <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-color) 100%); mix-blend-mode: multiply;"></div>
                
                <!-- Floating Shapes -->
                <div class="auth-shape bg-white opacity-10 rounded-circle position-absolute" style="width: 300px; height: 300px; top: 10%; left: 10%; filter: blur(50px);"></div>
                <div class="auth-shape bg-secondary opacity-25 rounded-circle position-absolute" style="width: 200px; height: 200px; bottom: 20%; right: 10%; filter: blur(40px);"></div>

                <div class="z-2 text-center text-white p-5 animate-fade-in">
                    <div class="mb-4">
                        <div class="bg-white bg-opacity-10 p-4 rounded-circle d-inline-block shadow-lg">
                            <i class="fas fa-rocket fa-4x text-white"></i>
                        </div>
                    </div>
                    <h1 class="display-3 fw-bold mb-3">JOB NOW</h1>
                    <p class="lead text-white text-opacity-75 mb-5 fs-4">
                        Kết nối nhân tài, kiến tạo tương lai.
                    </p>
                    <div class="d-flex justify-content-center gap-4 text-start">
                        <div class="d-flex align-items-center gap-3 bg-white bg-opacity-10 p-3 rounded-lg backdrop-blur-sm">
                            <i class="fas fa-briefcase fa-2x"></i>
                            <div>
                                <h5 class="mb-0 fw-bold">3000+</h5>
                                <small class="text-white-50">Việc làm mới</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 bg-white bg-opacity-10 p-3 rounded-lg backdrop-blur-sm">
                            <i class="fas fa-users fa-2x"></i>
                            <div>
                                <h5 class="mb-0 fw-bold">1M+</h5>
                                <small class="text-white-50">Ứng viên</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Form -->
            <div class="col-lg-6 d-flex align-items-center bg-white position-relative">
                <div class="w-100 p-4 p-md-5 mx-auto" style="max-width: 600px;">
                    <div class="text-center mb-5">
                         <h2 class="fw-bold mb-2 text-dark">Chào mừng trở lại!</h2>
                         <p class="text-muted">Đăng nhập để tiếp tục hành trình sự nghiệp</p>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success d-flex align-items-center rounded-lg shadow-sm border-0 bg-success bg-opacity-10 text-success mb-4">
                            <i class="fas fa-check-circle me-2 fa-lg"></i>@TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="Login" method="post" class="needs-validation" novalidate>
                        <input type="hidden" asp-for="ReturnUrl" value="@ViewData["ReturnUrl"]" />
                        
                        <!-- Role Selection Cards -->
                        <div class="mb-5">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-3 letter-spacing-1">
                                Chọn vai trò đăng nhập
                            </label>
                            <div class="row g-3">
                                <div class="col-6">
                                    <input type="radio" asp-for="VaiTro" value="Ứng viên" id="roleCandidate" class="btn-check" checked>
                                    <label class="role-selector-card btn btn-outline-light w-100 p-3 text-start h-100 position-relative border-2" for="roleCandidate">
                                        <div class="d-flex flex-column align-items-center text-center gap-2">
                                            <div class="icon-circle bg-primary bg-opacity-10 text-primary rounded-circle p-2 mb-1">
                                                <i class="fas fa-user-graduate fa-lg"></i>
                                            </div>
                                            <div>
                                                <span class="d-block fw-bold text-dark">Ứng viên</span>
                                                <small class="text-muted" style="font-size: 0.75rem;">Tìm việc làm</small>
                                            </div>
                                        </div>
                                        <div class="check-indicator position-absolute top-0 end-0 m-2 text-primary opacity-0 transition-all">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-6">
                                    <input type="radio" asp-for="VaiTro" value="Doanh nghiệp" id="roleEmployer" class="btn-check">
                                    <label class="role-selector-card btn btn-outline-light w-100 p-3 text-start h-100 position-relative border-2" for="roleEmployer">
                                        <div class="d-flex flex-column align-items-center text-center gap-2">
                                            <div class="icon-circle bg-success bg-opacity-10 text-success rounded-circle p-2 mb-1">
                                                <i class="fas fa-building fa-lg"></i>
                                            </div>
                                            <div>
                                                <span class="d-block fw-bold text-dark">Doanh nghiệp</span>
                                                <small class="text-muted" style="font-size: 0.75rem;">Đăng tuyển dụng</small>
                                            </div>
                                        </div>
                                        <div class="check-indicator position-absolute top-0 end-0 m-2 text-primary opacity-0 transition-all">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="VaiTro" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <!-- Inputs -->
                        <div class="form-floating mb-3">
                            <input asp-for="TenDangNhap" class="form-control bg-light border-0 rounded-lg fw-medium ps-4" id="username" placeholder="name@example.com">
                            <label for="username" class="text-muted ps-4">Tên đăng nhập</label>
                            <span asp-validation-for="TenDangNhap" class="text-danger small ms-2"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="MatKhau" class="form-control bg-light border-0 rounded-lg fw-medium ps-4" id="password" placeholder="Password">
                            <label for="password" class="text-muted ps-4">Mật khẩu</label>
                            <span asp-validation-for="MatKhau" class="text-danger small ms-2"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="GhiNhoDangNhap" class="form-check-input" id="rememberMe">
                                <label class="form-check-label text-muted small" for="rememberMe">Ghi nhớ đăng nhập</label>
                            </div>
                            <a href="#" class="text-primary small text-decoration-none fw-bold">Quên mật khẩu?</a>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 rounded-lg small border-0 bg-danger bg-opacity-10 text-danger" role="alert"></div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-lg hover-lift py-3 fw-bold">
                            Đăng nhập <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <div class="text-center mt-5">
                        <p class="text-muted mb-0">
                            Chưa có tài khoản? 
                            <a asp-action="Register" class="text-primary text-decoration-none fw-bold ms-1">Đăng ký ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Custom Auth Styles */
.role-selector-card {
    transition: all 0.2s ease;
    border-color: #f1f5f9 !important;
    background-color: #fff !important;
}

.role-selector-card:hover {
    border-color: var(--primary-color) !important;
    background-color: #f8fafc !important;
    transform: translateY(-2px);
}

.btn-check:checked + .role-selector-card {
    border-color: var(--primary-color) !important;
    background-color: #eff6ff !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.btn-check:checked + .role-selector-card .check-indicator {
    opacity: 1 !important;
}

.btn-check:checked + .role-selector-card .icon-circle {
    background-color: var(--primary-color) !important;
    color: white !important;
}

/* Background Pattern */
.auth-bg-pattern {
    background-image: radial-gradient(#ffffff 2px, transparent 2px);
    background-size: 30px 30px;
}

.form-floating > .form-control:focus {
    box-shadow: none;
    background-color: #fff !important;
    border: 2px solid var(--primary-color) !important;
}

.backdrop-blur-sm {
    backdrop-filter: blur(4px);
}
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
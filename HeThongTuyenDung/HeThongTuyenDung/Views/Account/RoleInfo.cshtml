@{
    ViewData["Title"] = "Chọn vai trò của bạn";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-4">
                <h2 class="mb-3">Bạn muốn sử dụng hệ thống với vai trò nào?</h2>
                <p class="text-muted">
                    Vui lòng chọn vai trò phù hợp để chúng tôi thiết lập trải nghiệm tốt nhất cho bạn.
                </p>
            </div>

            <div class="row g-4">
                <!-- Ứng viên -->
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="fas fa-user-graduate fa-3x text-primary mb-3"></i>
                            <h4 class="card-title mb-2">Ứng viên</h4>
                            <p class="card-text text-muted mb-4">
                                Tạo hồ sơ, tìm kiếm và ứng tuyển vào các việc làm phù hợp.
                            </p>
                            <a asp-controller="Account"
                               asp-action="Register"
                               asp-route-role="Ứng viên"
                               class="btn btn-primary">
                                Đăng ký làm ứng viên
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Doanh nghiệp -->
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body text-center">
                            <i class="fas fa-building fa-3x text-success mb-3"></i>
                            <h4 class="card-title mb-2">Doanh nghiệp</h4>
                            <p class="card-text text-muted mb-4">
                                Đăng tin tuyển dụng, quản lý ứng viên và quy trình tuyển dụng.
                            </p>
                            <a asp-controller="Account"
                               asp-action="Register"
                               asp-route-role="Doanh nghiệp"
                               class="btn btn-success">
                                Đăng ký cho doanh nghiệp
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại trang chủ
                </a>
            </div>
        </div>
    </div>
</div>



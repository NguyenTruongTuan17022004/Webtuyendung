@model HeThongTuyenDung.Models.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
    ViewData["HideLayout"] = true;
}

<div class="auth-wrapper">
    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100">
             <!-- Left Side: Hero/Branding -->
            <div class="col-lg-5 d-none d-lg-flex position-relative align-items-center justify-content-center bg-secondary overflow-hidden">
                <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); mix-blend-mode: normal;"></div>
                
                 <!-- Floating Shapes -->
                <div class="auth-shape bg-white opacity-10 rounded-pill position-absolute" style="width: 400px; height: 400px; top: -10%; left: -20%; filter: blur(60px); transform: rotate(45deg);"></div>
                
                <div class="z-2 text-center text-white p-5 animate-fade-in">
                    <h1 class="display-4 fw-bold mb-3">Tham gia <br/>JOB NOW</h1>
                    <p class="lead text-white text-opacity-90 mb-5">
                       Cánh cửa dẫn đến sự nghiệp mơ ước của bạn.
                    </p>
                    
                    <div class="row g-4 text-start">
                         <div class="col-12">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white bg-opacity-20 p-2 rounded-circle">
                                     <i class="fas fa-check fa-lg"></i>
                                </div>
                                <span>Tạo hồ sơ chuyên nghiệp miễn phí</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white bg-opacity-20 p-2 rounded-circle">
                                     <i class="fas fa-check fa-lg"></i>
                                </div>
                                <span>Ứng tuyển nhanh chóng 1 chạm</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white bg-opacity-20 p-2 rounded-circle">
                                     <i class="fas fa-check fa-lg"></i>
                                </div>
                                <span>Nhận thông báo việc làm mới nhất</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Form -->
            <div class="col-lg-7 d-flex align-items-center bg-white">
                <div class="w-100 p-4 p-md-5 mx-auto" style="max-width: 700px;">
                    <div class="text-center mb-5">
                        <h2 class="fw-bold mb-2">Đăng ký tài khoản</h2>
                        <p class="text-muted">Hoàn toàn miễn phí và chỉ mất 1 phút</p>
                    </div>

                    <form asp-action="Register" method="post" class="needs-validation" novalidate>
                        <!-- Role Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-3 letter-spacing-1">
                                Bạn là...
                            </label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <input type="radio" asp-for="VaiTro" value="Ứng viên" id="roleCandidate" class="btn-check" checked>
                                    <label class="role-selector-card btn btn-outline-light w-100 p-3 text-start h-100 position-relative border-2" for="roleCandidate">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-circle bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                                <i class="fas fa-user-graduate fa-lg"></i>
                                            </div>
                                            <div>
                                                <span class="d-block fw-bold text-dark">Ứng viên</span>
                                                <small class="text-muted">Tôi muốn tìm việc làm</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-md-6">
                                    <input type="radio" asp-for="VaiTro" value="Doanh nghiệp" id="roleEmployer" class="btn-check">
                                    <label class="role-selector-card btn btn-outline-light w-100 p-3 text-start h-100 position-relative border-2" for="roleEmployer">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-circle bg-success bg-opacity-10 text-success rounded-circle p-3">
                                                <i class="fas fa-building fa-lg"></i>
                                            </div>
                                            <div>
                                                <span class="d-block fw-bold text-dark">Doanh nghiệp</span>
                                                <small class="text-muted">Tôi muốn đăng tin tuyển dụng</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>

                         <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="HoTen" class="form-control bg-light border-0 rounded-lg" id="fullName" placeholder="Họ tên" />
                                    <label for="fullName">Họ và tên</label>
                                    <span asp-validation-for="HoTen" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="TenDangNhap" class="form-control bg-light border-0 rounded-lg" id="username" placeholder="Username" />
                                    <label for="username">Tên đăng nhập</label>
                                    <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control bg-light border-0 rounded-lg" id="email" placeholder="Email" />
                            <label for="email">Email</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                         <div class="form-floating mb-3">
                            <input asp-for="SoDienThoai" class="form-control bg-light border-0 rounded-lg" id="phone" placeholder="Phone" />
                            <label for="phone">Số điện thoại</label>
                            <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="MatKhau" class="form-control bg-light border-0 rounded-lg" id="password" placeholder="Password" />
                                    <label for="password">Mật khẩu</label>
                                    <span asp-validation-for="MatKhau" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="XacNhanMatKhau" class="form-control bg-light border-0 rounded-lg" id="confirmPassword" placeholder="Confirm Password" />
                                    <label for="confirmPassword">Nhập lại mật khẩu</label>
                                    <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="DongYDieuKhoan" class="form-check-input" id="terms" />
                            <label class="form-check-label text-muted small" for="terms">
                                Tôi đồng ý với <a href="#" class="text-primary text-decoration-none">Điều khoản sử dụng</a> và <a href="#" class="text-primary text-decoration-none">Chính sách bảo mật</a>
                            </label>
                            <span asp-validation-for="DongYDieuKhoan" class="text-danger d-block small"></span>
                        </div>
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 border-0 bg-danger bg-opacity-10 text-danger rounded-lg small" role="alert"></div>

                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill shadow-lg hover-lift py-3 fw-bold">
                            Tạo tài khoản <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <div class="text-center mt-5">
                        <p class="text-muted mb-0">
                            Đã có tài khoản? 
                            <a asp-action="Login" class="text-success text-decoration-none fw-bold ms-1">Đăng nhập ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Reuse styles from Login for consistency */
.role-selector-card {
    transition: all 0.2s ease;
    border-color: #f1f5f9 !important;
    background-color: #fff !important;
}

.role-selector-card:hover {
    border-color: #10b981 !important; /* Success color */
    background-color: #f0fdf4 !important;
    transform: translateY(-2px);
}

.btn-check:checked + .role-selector-card {
    border-color: #10b981 !important;
    background-color: #ecfdf5 !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.btn-check:checked + .role-selector-card .icon-circle {
    background-color: #10b981 !important;
    color: white !important;
}

.form-floating > .form-control:focus {
    box-shadow: none;
    background-color: #fff !important;
    border: 2px solid #10b981 !important;
}
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
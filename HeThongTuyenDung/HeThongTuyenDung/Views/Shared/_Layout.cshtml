<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JOB NOW</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HeThongTuyenDung.styles.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["HideLayout"] == null)
    {
        <header>
            <nav class="navbar navbar-expand-lg fixed-top">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-controller="Job" asp-action="Index">
                        <i class="fas fa-layer-group me-2 text-primary"></i>JOB NOW
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1 ms-lg-4">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Job" asp-action="Index">
                                    <i class="fas fa-home me-1"></i>Trang chủ
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Job" asp-action="Search">
                                    <i class="fas fa-search me-1"></i>Tìm việc
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Companies">
                                    <i class="fas fa-building me-1"></i>Công ty
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="News">
                                    <i class="fas fa-newspaper me-1"></i>Tin tức
                                </a>
                            </li>
                        </ul>
                        <ul class="navbar-nav align-items-center">
                            @if (Context.Session.GetString("UserId") != null)
                            {
                                var userRole = Context.Session.GetString("UserRole");
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle fw-bold" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <div class="d-inline-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-1 me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                <i class="fas fa-user"></i>
                                            </div>
                                            @Context.Session.GetString("UserName")
                                        </div>
                                    </a>
                                    <ul class="dropdown-menu border-0 shadow-lg" aria-labelledby="navbarDropdown">
                                        <li class="px-3 py-2 text-muted x-small text-uppercase fw-bold" style="font-size: 0.75rem;">
                                            @userRole
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
                                            <i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fas fa-user-cog me-2 text-secondary"></i>Thông tin cá nhân
                                        </a></li>
                                        
                                        @if (userRole == "Ứng viên")
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" asp-controller="Job" asp-action="MyApplications">
                                                <i class="fas fa-file-alt me-2 text-info"></i>Hồ sơ ứng tuyển
                                            </a></li>
                                            <li><a class="dropdown-item" asp-controller="Job" asp-action="SavedJobs">
                                                <i class="fas fa-heart me-2 text-danger"></i>Việc làm đã lưu
                                            </a></li>
                                        }
                                        else if (userRole == "Doanh nghiệp")
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" asp-controller="Job" asp-action="PostJob">
                                                <i class="fas fa-plus-circle me-2 text-success"></i>Đăng tin mới
                                            </a></li>
                                            <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="ManageApplications">
                                                <i class="fas fa-users me-2 text-info"></i>Quản lý ứng viên
                                            </a></li>
                                        }
                                        
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-block w-100">
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </li>
                                
                                @if (userRole == "Doanh nghiệp")
                                {
                                    <li class="nav-item ms-2">
                                        <a class="btn btn-primary btn-sm px-4 rounded-pill" asp-controller="Job" asp-action="PostJob">
                                            <i class="fas fa-plus me-1"></i>Đăng tin
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-bold" asp-controller="Account" asp-action="Login">
                                        Đăng nhập
                                    </a>
                                </li>
                                <li class="nav-item ms-2">
                                    <a class="btn btn-primary px-4 rounded-pill shadow-sm" asp-controller="Account" asp-action="Register">
                                        Đăng ký ngay
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    @RenderBody()

    @if (ViewData["HideLayout"] == null)
    {
        <footer>
            <div class="container">
                <div class="row gy-4">
                    <div class="col-lg-5 mb-4">
                        <h5 class="mb-4 text-white d-flex align-items-center">
                            <i class="fas fa-layer-group me-2 text-primary"></i>JOB NOW
                        </h5>
                        <p class="text-secondary mb-4" style="max-width: 300px;">
                            Nền tảng tuyển dụng thông minh, kết nối nhân tài với những cơ hội nghề nghiệp tốt nhất. Nâng tầm sự nghiệp của bạn ngay hôm nay.
                        </p>
                        <div class="social-links d-flex gap-3">
                            <a href="#" class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="fab fa-linkedin-in"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-2 col-6 mb-4">
                        <h6 class="text-white fw-bold mb-3">Ứng viên</h6>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li><a href="#" class="text-muted text-decoration-none">Tìm việc làm</a></li>
                            <li><a href="#" class="text-muted text-decoration-none">Tạo CV</a></li>
                            <li><a href="#" class="text-muted text-decoration-none">Cẩm nang</a></li>
                            <li><a href="#" class="text-muted text-decoration-none">Ứng dụng Mobile</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-2 col-6 mb-4">
                        <h6 class="text-white fw-bold mb-3">Doanh nghiệp</h6>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li><a href="#" class="text-muted text-decoration-none">Đăng tin</a></li>
                            <li><a href="#" class="text-muted text-decoration-none">Tìm hồ sơ</a></li>
                            <li><a href="#" class="text-muted text-decoration-none">Báo giá</a></li>
                            <li><a href="#" class="text-muted text-decoration-none">Đối tác</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-12 mb-4">
                        <h6 class="text-white fw-bold mb-3">Liên hệ</h6>
                        <ul class="list-unstyled text-muted">
                            <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 123 Đường ABC, Hà Nội</li>
                            <li class="mb-2"><i class="fas fa-phone me-2 text-primary"></i> 1900-1234</li>
                            <li><i class="fas fa-envelope me-2 text-primary"></i> contact@jobnow.com</li>
                        </ul>
                    </div>
                </div>
                <hr class="my-5 border-secondary opacity-25">
                <div class="row align-items-center pb-4">
                    <div class="col-md-6 text-center text-md-start">
                        <p class="mb-0 text-secondary small">&copy; 2025 JOB NOW Recruitment. Designed with <i class="fas fa-heart text-danger mx-1"></i> by Team.</p>
                    </div>
                    <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                        <div class="opacity-75">
                             <span class="badge bg-white text-dark me-2 border"><i class="fab fa-cc-visa fa-lg"></i></span>
                             <span class="badge bg-white text-dark me-2 border"><i class="fab fa-cc-mastercard fa-lg"></i></span>
                             <span class="badge bg-white text-dark border"><i class="fab fa-cc-paypal fa-lg"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
